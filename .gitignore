# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Astro / Vite build and cache
.astro/
dist/

# Cloudflare Wrangler cache
.wrangler/

# ── Capacitor Native Projects ─────────────────────────────────────────────────
# Keep: android/ and ios/ project sources (manifests, build.gradle, Swift files)
# Ignore: generated build artefacts, local signing configs, Pods cache

# Android build outputs and local configs
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/app/google-services.json
android/app/keystore.properties

# Release keystore — NEVER commit; back up securely
*.keystore
*.jks

# iOS CocoaPods and Xcode derived data (regenerated with `pod install`)
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/DerivedData/
ios/.xcode.env.local

# Capacitor CLI temp files
.capacitor/

# Playwright test artifacts
test-results/
playwright-report/
blob-report/
playwright/.cache/

