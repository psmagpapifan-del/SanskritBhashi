---
import { AlertCircle, Home } from "lucide-react";
import Layout from "../layouts/Layout.astro";
---

<Layout lang="en" title="Page Not Found (404) | Sanskritbhashi">
  <div class="flex flex-col items-center justify-center py-20 text-center max-w-lg mx-auto">
    <AlertCircle class="w-16 h-16 text-saffron-500 mb-6 animate-float" />
    <h1 class="text-3xl font-extrabold text-charcoal mb-4 font-sans tracking-tight">404: Page Not Found.</h1>
    <p class="text-sm text-charcoal/70 mb-8 font-latin leading-relaxed">
      The page you are looking for does not exist or has been relocated. Let's get you back on track to learning Sanskrit.
    </p>
    <a
      href="/en"
      class="flex items-center gap-2 px-6 py-3 bg-saffron-500 hover:bg-saffron-600 text-white font-bold rounded-xl shadow-xs transition-colors cursor-pointer"
    >
      <Home class="w-4 h-4" /> Go back home
    </a>
  </div>
</Layout>
