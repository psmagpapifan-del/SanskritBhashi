---
import { Home, GraduationCap, BookMarked, Info, HelpCircle, ChevronLeft, Menu, Mail, Sun, Moon } from "lucide-react";
import LanguageSelector from "../components/LanguageSelector";
import StreakCounter from "../components/StreakCounter";
import OnboardingTour from "../components/OnboardingTour";
import ConfettiCelebration from "../components/ConfettiCelebration";
import { getTranslation } from "../lib/i18n";
import "../styles/globals.css";

interface Props {
  lang: string;
  title?: string;
  description?: string;
}

const { lang, title = "Sanskritbhashi | Learn and Practice Sanskrit", description = "Learn and practice Sanskrit grammar and Shastras" } = Astro.props;
const t = getTranslation(lang);

const navItems = [
  { name: t.nav.home, href: `/${lang}`, icon: Home, id: "tour-step-1" },
  { name: t.nav.schoolPrep, href: `/${lang}/modules/school-prep`, icon: GraduationCap, id: "tour-step-3" },
  { name: t.nav.shastraStudy, href: `/${lang}/modules/shastra-study`, icon: BookMarked, id: "tour-step-4" },
  { name: t.nav.about, href: `/${lang}/about`, icon: Info },
  { name: t.nav.contact, href: `/${lang}/contact`, icon: Mail },
  { name: t.nav.faqs, href: `/${lang}/faqs`, icon: HelpCircle, id: "tour-step-8" },
];

const pathname = Astro.url.pathname;
const cleanPath = pathname.replace(/\/$/, "");
const canonicalURL = `https://sanskritbhashi.com${cleanPath}`;

const isActive = (href: string) => {
  // Normalize pathnames by removing trailing shashes for comparison
  const normPath = pathname.replace(/\/$/, "");
  const normHref = href.replace(/\/$/, "");
  if (normHref === `/${lang}`) {
    return normPath === normHref || normPath === "";
  }
  return normPath.startsWith(normHref);
};
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico?v=4" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=4" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=4" />

    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#FF6F00" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="संस्कृतभाषी" />
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <!-- Google tag (gtag.js) Conditional Loading -->
    <script is:inline>
      function loadGoogleAnalytics() {
        const consent = localStorage.getItem('cookie-consent');
        const consentAnalytics = localStorage.getItem('cookie-consent-analytics');
        const isConsentGranted = consent === 'accepted' || consentAnalytics === 'true';

        if (isConsentGranted && !window.gtagInitialized) {
          window.gtagInitialized = true;
          
          const script = document.createElement('script');
          script.async = true;
          script.src = "https://www.googletagmanager.com/gtag/js?id=G-MKCEGWRH04";
          document.head.appendChild(script);

          window.dataLayer = window.dataLayer || [];
          window.gtag = function() { window.dataLayer.push(arguments); };
          gtag('js', new Date());
          gtag('config', 'G-MKCEGWRH04');
        }
      }
      loadGoogleAnalytics();
      window.addEventListener('cookie-consent-updated', loadGoogleAnalytics);
      document.addEventListener('astro:after-swap', loadGoogleAnalytics);
    </script>
    <slot name="head" />
  </head>
  <body>
    <div class="flex flex-col md:flex-row min-h-dvh bg-cream text-charcoal w-full transition-colors duration-200">
      {/* Confetti & Tour Providers */}
      <ConfettiCelebration client:only="react" />
      <OnboardingTour client:only="react" />

      {/* MOBILE TOP BAR (Only visible on mobile/tablet) */}
      <header class="md:hidden sticky top-0 flex items-center justify-between px-4 py-3 bg-white/95 dark:bg-zinc-950/95 backdrop-blur-md border-b border-border-hairline z-30 shadow-xs w-full">
        <a href={`/${lang}`} class="flex items-center gap-1.5">
          <span class="text-xl font-bold bg-linear-to-r from-saffron-500 to-saffron-600 bg-clip-text text-transparent font-sanskrit">
            संस्कृतभाषी
          </span>
          <span class="text-xs font-bold uppercase tracking-wider text-charcoal/40 font-latin hidden xs:inline">
            bhashi
          </span>
        </a>
        <div class="flex items-center gap-2">
          <button
            id="theme-toggle-mobile"
            class="relative flex items-center justify-center w-9 h-9 shrink-0 rounded-xl border border-border-hairline hover:bg-saffron-50 dark:hover:bg-zinc-900 transition-colors overflow-hidden"
            aria-label="Toggle theme"
          >
            <div class="absolute inset-0 flex items-center justify-center transition-all duration-500 -rotate-90 scale-0 opacity-0 dark:rotate-0 dark:scale-100 dark:opacity-100">
              <Sun class="w-5 h-5 text-marigold-500" className="w-5 h-5 text-marigold-500" />
            </div>
            <div class="absolute inset-0 flex items-center justify-center transition-all duration-500 rotate-0 scale-100 opacity-100 dark:rotate-90 dark:scale-0 dark:opacity-0">
              <Moon class="w-5 h-5 text-charcoal/70 dark:text-zinc-400" className="w-5 h-5 text-charcoal/70 dark:text-zinc-400" />
            </div>
          </button>
          <StreakCounter client:idle />
          <LanguageSelector client:load currentLang={lang} currentPathname={pathname} />
        </div>
      </header>

      {/* DESKTOP SIDEBAR (Only visible on desktop) */}
      <aside
        id="tour-step-2"
        class="group/sidebar hidden md:flex flex-col w-64 fixed h-dvh bg-white/80 dark:bg-zinc-950/80 backdrop-blur-xl border-r border-border-hairline dark:border-white/5 p-6 z-40 transition-all duration-300"
      >
        {/* Floating Toggle Button */}
        <button
          id="sidebar-toggle"
          class="absolute -right-3.5 top-8 w-7 h-7 rounded-full bg-white dark:bg-zinc-900 border border-border-hairline dark:border-white/10 flex items-center justify-center text-charcoal/50 hover:text-saffron-600 dark:hover:text-saffron-500 hover:bg-saffron-50 dark:hover:bg-zinc-800 shadow-sm transition-all duration-300 hover:scale-110 z-50 cursor-pointer"
          aria-label="Toggle Sidebar"
        >
          <ChevronLeft class="w-4 h-4 transition-transform duration-300" id="sidebar-toggle-icon" />
        </button>

        <div class="flex items-center mb-8 overflow-hidden h-10 shrink-0 relative">
          {/* Logo */}
          <a href={`/${lang}`} class="flex flex-col gap-0.5 select-none sidebar-text transition-all duration-300 w-auto opacity-100 visible overflow-hidden drop-shadow-sm">
            <span class="text-2xl font-black bg-linear-to-r from-saffron-500 to-saffron-600 bg-clip-text text-transparent font-sanskrit leading-none drop-shadow-sm">
              संस्कृतभाषी
            </span>
            <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 font-latin pl-1 leading-none">
              Sanskritbhashi.com
            </span>
          </a>
        </div>

        {/* Sidebar Nav */}
        <nav class="flex-1 space-y-1.5 overflow-y-auto [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
          {navItems.map((item) => {
            const active = isActive(item.href);
            const Icon = item.icon;
            return (
              <a
                href={item.href}
                id={item.id}
                class={`sidebar-link group relative flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold transition-all duration-300 cursor-pointer overflow-hidden ${
                  active
                    ? "bg-linear-to-r from-saffron-500 to-saffron-600 text-white shadow-lg shadow-saffron-500/20 ring-1 ring-white/20 dark:ring-white/10 scale-[1.02]"
                    : "text-charcoal/70 hover:bg-saffron-50 dark:hover:bg-white/5 hover:text-saffron-600 dark:hover:text-saffron-400 hover:-translate-y-0.5"
                }`}
              >
                {active && (
                  <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-1/2 bg-white rounded-r-full shadow-[0_0_8px_rgba(255,255,255,0.8)]"></div>
                )}
                <Icon class={`w-5 h-5 shrink-0 transition-colors ${active ? "text-white drop-shadow-md" : "text-charcoal/40 group-hover:text-saffron-500 dark:group-hover:text-saffron-400"}`} />
                <span class="sidebar-text transition-all duration-300 w-auto opacity-100 visible whitespace-nowrap">{item.name}</span>
                
                {/* Tooltip for collapsed state */}
                <div class="hidden group-data-[collapsed=true]/sidebar:block absolute left-14 opacity-0 group-hover:opacity-100 px-2.5 py-1 bg-charcoal dark:bg-zinc-800 text-cream text-[11px] font-bold rounded-md pointer-events-none transition-opacity duration-200 z-50 shadow-xl border border-white/5 whitespace-nowrap">
                  {item.name}
                </div>
              </a>
            );
          })}
        </nav>

        {/* Sidebar Footer */}
        <div class="border-t border-border-hairline pt-4 text-center overflow-hidden shrink-0 h-10">
          <p class="sidebar-text text-[10px] font-bold text-charcoal/30 font-latin uppercase tracking-widest transition-all duration-300 w-auto opacity-100 visible whitespace-nowrap">
            © 2026 Sanskritbhashi
          </p>
        </div>
      </aside>

      {/* DESKTOP HEADER & CONTENT AREA */}
      <div id="desktop-content-area" class="flex-1 flex flex-col md:pl-64 w-full transition-all duration-300">
        {/* DESKTOP TOP HEADER */}
        <header class="hidden md:flex items-center justify-between h-16 px-8 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md border-b border-border-hairline sticky top-0 z-30 w-full">
          <nav class="flex items-center gap-6 text-sm font-medium text-charcoal/70">
            <a href={`/${lang}/about`} class={`hover:text-saffron-600 transition-colors ${isActive(`/${lang}/about`) ? "text-saffron-600 font-bold" : ""}`}>{t.nav.about}</a>
            <a href={`/${lang}/contact`} class={`hover:text-saffron-600 transition-colors ${isActive(`/${lang}/contact`) ? "text-saffron-600 font-bold" : ""}`}>{t.nav.contact}</a>
            <a href={`/${lang}/privacy`} class={`hover:text-saffron-600 transition-colors ${isActive(`/${lang}/privacy`) ? "text-saffron-600 font-bold" : ""}`}>{t.nav.privacy}</a>
            <a href={`/${lang}/terms`} class={`hover:text-saffron-600 transition-colors ${isActive(`/${lang}/terms`) ? "text-saffron-600 font-bold" : ""}`}>{t.nav.terms}</a>
          </nav>
          <div class="flex items-center gap-4">
            <button
              id="theme-toggle-desktop"
              class="relative flex items-center justify-center w-9 h-9 shrink-0 rounded-xl border border-border-hairline hover:bg-saffron-50 dark:hover:bg-zinc-900 transition-colors overflow-hidden"
              aria-label="Toggle theme"
            >
              <div class="absolute inset-0 flex items-center justify-center transition-all duration-500 -rotate-90 scale-0 opacity-0 dark:rotate-0 dark:scale-100 dark:opacity-100">
                <Sun class="w-5 h-5 text-marigold-500" className="w-5 h-5 text-marigold-500" />
              </div>
              <div class="absolute inset-0 flex items-center justify-center transition-all duration-500 rotate-0 scale-100 opacity-100 dark:rotate-90 dark:scale-0 dark:opacity-0">
                <Moon class="w-5 h-5 text-charcoal/70 dark:text-zinc-400" className="w-5 h-5 text-charcoal/70 dark:text-zinc-400" />
              </div>
            </button>
            <StreakCounter client:idle />
            <LanguageSelector client:load currentLang={lang} currentPathname={pathname} />
          </div>
        </header>

        {/* MAIN BODY CONTENT */}
        <main class="flex-1 p-4 md:p-8 pb-24 md:pb-8 max-w-6xl w-full mx-auto flex flex-col">
          <div class="flex-1">
            <slot />
          </div>

          {/* GLOBAL MAIN FOOTER */}
          <footer class="mt-16 border-t border-border-hairline pt-8 pb-4 text-center text-xs text-charcoal/50 w-full">
            <div class="flex flex-wrap justify-center items-center gap-x-6 gap-y-2 mb-4 font-semibold">
              <a href={`/${lang}`} class="hover:text-saffron-600 transition-colors">{t.nav.home}</a>
              <a href={`/${lang}/about`} class="hover:text-saffron-600 transition-colors">{t.nav.about}</a>
              <a href={`/${lang}/contact`} class="hover:text-saffron-600 transition-colors">{t.nav.contact}</a>
              <a href={`/${lang}/privacy`} class="hover:text-saffron-600 transition-colors">{t.nav.privacy}</a>
              <a href={`/${lang}/terms`} class="hover:text-saffron-600 transition-colors">{t.nav.terms}</a>
              <a href={`/${lang}/faqs`} class="hover:text-saffron-600 transition-colors">{t.nav.faqs}</a>
              <button id="open-cookie-preferences" class="hover:text-saffron-600 transition-colors cursor-pointer bg-transparent border-0 p-0 font-semibold text-xs text-charcoal/50">Cookie Preferences</button>
            </div>
            <p class="text-[10px] tracking-wider uppercase opacity-75 font-mono">
              © 2026 Sanskritbhashi. All rights reserved.
            </p>
          </footer>
        </main>
      </div>

      {/* MOBILE BOTTOM NAVIGATION BAR (Duolingo style, only visible on mobile/tablet) */}
      <nav class="md:hidden fixed bottom-0 left-0 right-0 h-16 bg-white dark:bg-zinc-950 border-t border-border-hairline flex items-center justify-around px-2 z-30 shadow-lg w-full">
        {navItems.map((item) => {
          const active = isActive(item.href);
          const Icon = item.icon;
          return (
            <a
              href={item.href}
              class={`flex flex-col items-center justify-center flex-1 h-full min-w-[44px] min-h-[44px] transition-colors relative ${
                active ? "text-saffron-600" : "text-charcoal/50 hover:text-saffron-500"
              }`}
            >
              <Icon class="w-5 h-5 mb-0.5" />
              <span class="text-[9px] font-bold tracking-tight font-latin">
                {item.name.split(" ")[0]}
              </span>
              {active && (
                <span class="absolute bottom-1 w-1.5 h-1.5 bg-saffron-500 rounded-full" />
              )}
            </a>
          );
        })}
      </nav>
    </div>

    <!-- Cookie Consent Banner (AdSense Compliant) -->
    <div
      id="cookie-consent-banner"
      class="hidden fixed bottom-20 md:bottom-6 left-4 right-4 md:left-auto md:right-6 md:w-96 bg-white dark:bg-zinc-950 border border-border-hairline rounded-2xl p-5 shadow-xl z-50 animate-float font-latin"
    >
      <h4 class="text-sm font-bold text-charcoal mb-2">Cookie Consent & Personalization.</h4>
      <p class="text-xs text-charcoal/70 leading-relaxed mb-4">
        We and our advertising partners (including Google) use cookies to customize content and serve personalized ads based on your past visits. Read our <a href={`/${lang}/privacy`} class="text-saffron-600 underline font-semibold hover:text-saffron-500">Privacy Policy</a> to learn more.
      </p>
      <div class="flex gap-2">
        <button
          id="accept-cookies"
          class="flex-1 px-3 py-2 bg-saffron-500 hover:bg-saffron-600 text-white text-[11px] font-bold rounded-lg transition-colors cursor-pointer"
        >
          Accept All
        </button>
        <button
          id="decline-cookies"
          class="px-3 py-2 border border-border-hairline hover:bg-saffron-50 dark:hover:bg-zinc-900 text-charcoal text-[11px] font-semibold rounded-lg transition-colors cursor-pointer"
        >
          Decline
        </button>
        <button
          id="customize-cookies"
          class="px-3 py-2 border border-border-hairline hover:bg-saffron-50 dark:hover:bg-zinc-900 text-charcoal text-[11px] font-semibold rounded-lg transition-colors cursor-pointer"
        >
          Customize
        </button>
      </div>
    </div>

    <!-- Cookie Preferences Modal -->
    <dialog
      id="cookie-preferences-dialog"
      closedby="any"
      class="fixed inset-0 m-auto w-full max-w-md bg-white dark:bg-zinc-950 border border-border-hairline rounded-3xl p-6 shadow-2xl z-50 text-charcoal font-latin backdrop:bg-black/50 backdrop:backdrop-blur-xs"
    >
      <div class="flex flex-col h-full">
        <div class="flex items-center justify-between mb-4 border-b border-border-hairline pb-3">
          <h3 class="text-base font-bold text-charcoal">Cookie Preferences</h3>
          <button
            id="close-preferences-x"
            class="text-charcoal/50 hover:text-charcoal p-1.5 rounded-lg border border-border-hairline hover:bg-saffron-50 dark:hover:bg-zinc-900 transition-colors cursor-pointer"
            aria-label="Close dialog"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <p class="text-xs text-charcoal/70 leading-relaxed mb-5">
          Customize how cookies are used on our site. Some cookies are essential for the website to function, while others help us personalize ads and analyze traffic.
        </p>

        <!-- Preference Toggles -->
        <div class="space-y-4 mb-6">
          <!-- Necessary -->
          <div class="flex items-start justify-between gap-4 p-3 rounded-xl border border-border-hairline bg-cream/30 dark:bg-zinc-900/30">
            <div class="flex-1">
              <h4 class="text-xs font-bold text-charcoal flex items-center gap-1.5">
                Strictly Necessary Cookies
                <span class="text-[9px] px-1.5 py-0.5 bg-saffron-500/10 dark:bg-saffron-500/20 text-saffron-600 dark:text-saffron-400 rounded-md font-extrabold uppercase">Required</span>
              </h4>
              <p class="text-[10px] text-charcoal/60 leading-normal mt-1">
                Essential for basic features like language preference preservation, dark/light mode toggles, and secure navigation.
              </p>
            </div>
            <div class="relative flex items-center select-none mt-1">
              <input type="checkbox" checked disabled class="sr-only peer" />
              <div class="w-10 h-6 bg-saffron-500 rounded-full peer-disabled:opacity-50"></div>
              <div class="absolute left-[20px] top-[4px] bg-white w-4 h-4 rounded-full transition-transform"></div>
            </div>
          </div>

          <!-- Personalization & Ads -->
          <div class="flex items-start justify-between gap-4 p-3 rounded-xl border border-border-hairline">
            <div class="flex-1">
              <h4 class="text-xs font-bold text-charcoal">Personalization & Ads</h4>
              <p class="text-[10px] text-charcoal/60 leading-normal mt-1">
                Allows Google and ad partners to serve personalized ads based on your past visits to this or other websites.
              </p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer mt-1">
              <input type="checkbox" id="cookie-pref-ads" class="sr-only peer" />
              <div class="w-10 h-6 bg-zinc-200 dark:bg-zinc-800 peer-focus:outline-hidden rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:border-zinc-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-zinc-700 peer-checked:bg-saffron-500"></div>
            </label>
          </div>

          <!-- Analytics -->
          <div class="flex items-start justify-between gap-4 p-3 rounded-xl border border-border-hairline">
            <div class="flex-1">
              <h4 class="text-xs font-bold text-charcoal">Analytics & Performance</h4>
              <p class="text-[10px] text-charcoal/60 leading-normal mt-1">
                Helps us understand how users interact with the site, allowing us to analyze page performance and improve courses.
              </p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer mt-1">
              <input type="checkbox" id="cookie-pref-analytics" class="sr-only peer" />
              <div class="w-10 h-6 bg-zinc-200 dark:bg-zinc-800 peer-focus:outline-hidden rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:border-zinc-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-zinc-700 peer-checked:bg-saffron-500"></div>
            </label>
          </div>
        </div>

        <div class="flex gap-2 border-t border-border-hairline pt-4 mt-auto">
          <button
            id="cookie-save-preferences"
            class="flex-1 px-4 py-2.5 bg-saffron-500 hover:bg-saffron-600 text-white text-xs font-bold rounded-lg transition-colors cursor-pointer"
          >
            Save Choices
          </button>
          <button
            id="cookie-accept-all-pref"
            class="px-4 py-2.5 border border-border-hairline hover:bg-saffron-50 dark:hover:bg-zinc-900 text-charcoal text-xs font-semibold rounded-lg transition-colors cursor-pointer"
          >
            Accept All
          </button>
        </div>
      </div>
    </dialog>

    <script is:inline>
      function setupThemeToggle() {
        const desktopBtn = document.getElementById('theme-toggle-desktop');
        const mobileBtn = document.getElementById('theme-toggle-mobile');
        
        function toggle(event) {
          const isDark = document.documentElement.classList.contains('dark');
          const newTheme = isDark ? 'light' : 'dark';

          if (!document.startViewTransition) {
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', newTheme);
            return;
          }

          let x = event?.clientX ?? window.innerWidth / 2;
          let y = event?.clientY ?? 50;

          const btn = event?.currentTarget;
          if (btn instanceof Element) {
            const rect = btn.getBoundingClientRect();
            // Validate the button is actually visible before using its coordinates
            if (rect.width > 0 && rect.height > 0) {
              x = window.innerWidth - 75; // Fine-tuned slightly left from the far right edge
              y = rect.top + rect.height / 2;
            }
          }
          
          const endRadius = Math.hypot(
            Math.max(x, window.innerWidth - x),
            Math.max(y, window.innerHeight - y)
          );

          const transition = document.startViewTransition(() => {
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', newTheme);
          });

          transition.ready.then(() => {
            const clipPath = [
              `circle(0px at ${x}px ${y}px)`,
              `circle(${endRadius}px at ${x}px ${y}px)`
            ];

            document.documentElement.animate(
              {
                clipPath: clipPath
              },
              {
                duration: 500,
                easing: 'ease-in-out',
                pseudoElement: '::view-transition-new(root)'
              }
            );
          });
        }
        
        if (desktopBtn) desktopBtn.addEventListener('click', toggle);
        if (mobileBtn) mobileBtn.addEventListener('click', toggle);
      }

      setupThemeToggle();
      document.addEventListener('astro:after-swap', setupThemeToggle);

      function setupCookieBanner() {
        const banner = document.getElementById('cookie-consent-banner');
        const acceptBtn = document.getElementById('accept-cookies');
        const declineBtn = document.getElementById('decline-cookies');
        const customizeBtn = document.getElementById('customize-cookies');
        const dialog = document.getElementById('cookie-preferences-dialog');
        const closeXBtn = document.getElementById('close-preferences-x');
        const savePrefBtn = document.getElementById('cookie-save-preferences');
        const acceptAllPrefBtn = document.getElementById('cookie-accept-all-pref');
        const footerBtn = document.getElementById('open-cookie-preferences');

        const prefAds = document.getElementById('cookie-pref-ads');
        const prefAnalytics = document.getElementById('cookie-pref-analytics');

        if (!banner || !acceptBtn || !declineBtn || !customizeBtn || !dialog) return;

        // Initialize state from localStorage
        function loadPreferences() {
          const consent = localStorage.getItem('cookie-consent');
          const consentAds = localStorage.getItem('cookie-consent-ads');
          const consentAnalytics = localStorage.getItem('cookie-consent-analytics');

          if (consent === 'accepted') {
            if (prefAds) prefAds.checked = true;
            if (prefAnalytics) prefAnalytics.checked = true;
          } else if (consent === 'declined') {
            if (prefAds) prefAds.checked = false;
            if (prefAnalytics) prefAnalytics.checked = false;
          } else {
            if (prefAds) prefAds.checked = consentAds === 'true';
            if (prefAnalytics) prefAnalytics.checked = consentAnalytics === 'true';
          }
        }

        // Show banner if no consent exists
        const consent = localStorage.getItem('cookie-consent');
        if (consent === null) {
          banner.classList.remove('hidden');
        }

        // Action: Accept All
        function acceptAll() {
          localStorage.setItem('cookie-consent', 'accepted');
          localStorage.setItem('cookie-consent-necessary', 'true');
          localStorage.setItem('cookie-consent-ads', 'true');
          localStorage.setItem('cookie-consent-analytics', 'true');
          banner.classList.add('hidden');
          dialog.close();
          window.dispatchEvent(new Event('cookie-consent-updated'));
        }

        // Action: Decline
        function declineAll() {
          localStorage.setItem('cookie-consent', 'declined');
          localStorage.setItem('cookie-consent-necessary', 'true');
          localStorage.setItem('cookie-consent-ads', 'false');
          localStorage.setItem('cookie-consent-analytics', 'false');
          banner.classList.add('hidden');
          dialog.close();
          window.dispatchEvent(new Event('cookie-consent-updated'));
        }

        // Action: Save Custom choices
        function saveCustomChoices() {
          const ads = prefAds ? prefAds.checked : false;
          const analytics = prefAnalytics ? prefAnalytics.checked : false;

          localStorage.setItem('cookie-consent', 'custom');
          localStorage.setItem('cookie-consent-necessary', 'true');
          localStorage.setItem('cookie-consent-ads', ads ? 'true' : 'false');
          localStorage.setItem('cookie-consent-analytics', analytics ? 'true' : 'false');

          banner.classList.add('hidden');
          dialog.close();
          window.dispatchEvent(new Event('cookie-consent-updated'));
        }

        // Event Listeners
        acceptBtn.addEventListener('click', acceptAll);
        declineBtn.addEventListener('click', declineAll);
        customizeBtn.addEventListener('click', () => {
          loadPreferences();
          dialog.showModal();
        });

        if (footerBtn) {
          footerBtn.addEventListener('click', (e) => {
            e.preventDefault();
            loadPreferences();
            dialog.showModal();
          });
        }

        if (closeXBtn) {
          closeXBtn.addEventListener('click', () => {
            dialog.close();
          });
        }

        if (savePrefBtn) {
          savePrefBtn.addEventListener('click', saveCustomChoices);
        }

        if (acceptAllPrefBtn) {
          acceptAllPrefBtn.addEventListener('click', acceptAll);
        }

        // Backdrop click / Light-dismiss fallback for unsupported browsers
        if (!('closedBy' in HTMLDialogElement.prototype)) {
          dialog.addEventListener('click', (event) => {
            if (event.target !== dialog) return;
            const rect = dialog.getBoundingClientRect();
            const isDialogContent = (
              rect.top <= event.clientY &&
              event.clientY <= rect.top + rect.height &&
              rect.left <= event.clientX &&
              event.clientX <= rect.left + rect.width
            );
            if (!isDialogContent) {
              dialog.close();
            }
          });
        }
      }

      setupCookieBanner();
      document.addEventListener('astro:after-swap', setupCookieBanner);
      function setupSidebarToggle() {
        const toggleBtn = document.getElementById('sidebar-toggle');
        const sidebar = document.getElementById('tour-step-2');
        const content = document.getElementById('desktop-content-area');
        const texts = document.querySelectorAll('.sidebar-text');
        const links = document.querySelectorAll('.sidebar-link');
        const toggleIcon = document.getElementById('sidebar-toggle-icon');
        
        if (!toggleBtn || !sidebar || !content) return;

        let isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';

        function applyState(animate = true) {
          if (!animate) {
            sidebar.classList.remove('transition-all', 'duration-300');
            content.classList.remove('transition-all', 'duration-300');
          }

          if (isCollapsed) {
            if (sidebar.classList.contains('w-64')) {
              sidebar.dataset.collapsed = "true";
              sidebar.classList.replace('w-64', 'w-20');
              sidebar.classList.replace('p-6', 'p-4');
              content.classList.replace('md:pl-64', 'md:pl-20');
              toggleIcon.classList.add('rotate-180');
              texts.forEach(t => {
                t.classList.remove('w-auto', 'opacity-100', 'visible');
                t.classList.add('w-0', 'opacity-0', 'invisible');
              });
              links.forEach(l => {
                l.classList.replace('px-4', 'px-0');
                l.classList.replace('gap-3', 'gap-0');
                l.classList.add('justify-center');
              });
            }
          } else {
            if (sidebar.classList.contains('w-20')) {
              delete sidebar.dataset.collapsed;
              sidebar.classList.replace('w-20', 'w-64');
              sidebar.classList.replace('p-4', 'p-6');
              content.classList.replace('md:pl-20', 'md:pl-64');
              toggleIcon.classList.remove('rotate-180');
              texts.forEach(t => {
                t.classList.remove('w-0', 'opacity-0', 'invisible');
                t.classList.add('w-auto', 'opacity-100', 'visible');
              });
              links.forEach(l => {
                l.classList.replace('px-0', 'px-4');
                l.classList.replace('gap-0', 'gap-3');
                l.classList.remove('justify-center');
              });
            }
          }

          if (!animate) {
            // Force layout recalculation
            void sidebar.offsetWidth;
            sidebar.classList.add('transition-all', 'duration-300');
            content.classList.add('transition-all', 'duration-300');
          }
        }

        // Apply immediately without animation
        applyState(false);

        toggleBtn.addEventListener('click', () => {
          isCollapsed = !isCollapsed;
          localStorage.setItem('sidebar-collapsed', isCollapsed);
          applyState(true);
        });
      }

      setupSidebarToggle();
      document.addEventListener('astro:after-swap', setupSidebarToggle);
    </script>
  </body>
</html>
